{
  "extends": ["//"],
  "tasks": {
    "dev": {
      "dependsOn": ["@next/docker-infra#up", "docker:build"],
      "cache": false,
      "persistent": true,
      "inputs": ["$TURBO_DEFAULT$", ".env", ".env.*"]
    },
    "docker:build": {
      "dependsOn": ["@next/docker-infra#up", "^build"],
      "cache": false
    },
    "build": {
      "env": ["NODE_ENV"],
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env", ".env.*"],
      "outputs": ["dist/**"]
    },
    "test": {
      "env": [
        "NODE_ENV",
        "ALLOWED_ORIGINS",
        "UFABC_PARSER_URL",
        "AWS_REGION",
        "AWS_ACCESS_KEY_ID",
        "AWS_SECRET_ACCESS_KEY",
        "OAUTH_GOOGLE_CLIENT_ID",
        "OAUTH_GOOGLE_SECRET",
        "JWT_SECRET",
        "MONGODB_CONNECTION_URL",
        "REDIS_CONNECTION_URL"
      ],
      "inputs": ["src/**/*.ts", "test/**/*.ts"]
    }
  }
}
